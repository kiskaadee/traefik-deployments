# Ollama Service Configuration - Example

# The domain name for the service
SERVICE_DOMAIN=ollama.yourdomain.com

# API Key for X-Ollama-Key header authentication (Router 1)
OLLAMA_API_KEY=your-secure-api-key-here

# The external Traefik proxy network name
PROXY_NETWORK=proxy-net

# Number of replicas
REPLICAS=1

# Local volume name or path for ollama data
OLLAMA_DATA_VOLUME=ollama_data
