# --- Service Configuration ---
SERVICE_NAME=learning-hub
SERVICE_DOMAIN=learning.arch-services.mywire.org
APP_PORT=8000

# --- Infrastructure Networks ---
# The name of the external network where Traefik is running
PROXY_NETWORK=proxy-net
# The name of the external network for the Docker socket proxy
SOCKET_PROXY_NETWORK=socket-net

# --- Application Secrets ---
# Optional: Turso (libSQL) configuration. 
# If empty, the app falls back to local SQLite at ./data/learning.db
TURSO_DATABASE_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=your_secure_token_here

# --- System Configuration ---
DOCKER_HOST=tcp://socket-proxy:2375
